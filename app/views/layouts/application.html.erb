<!DOCTYPE html>
<html data-bs-theme="light">
  <head>
    <title><%= content_for(:title) || "DSS Vendor Portal" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <script>
      (() => {
        const storageKey = "dss-vendor-portal-theme"
        const systemTheme = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light"
        let storedTheme

        try {
          storedTheme = localStorage.getItem(storageKey)
        } catch {
          storedTheme = null
        }

        document.documentElement.setAttribute("data-bs-theme", storedTheme || systemTheme)
      })()
    </script>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-body-tertiary text-body">
    <header class="portal-header sticky-top">
      <nav class="navbar portal-navbar bg-body border-bottom">
        <div class="container d-flex flex-wrap align-items-center gap-2 gap-md-3">
          <%= link_to "DSS Vendor Portal", root_path, class: "navbar-brand fw-semibold me-auto me-lg-3" %>

          <% if user_signed_in? %>
            <ul class="nav portal-tabs order-3 order-lg-0 mt-2 mt-lg-0 me-lg-auto gap-2">
              <li class="nav-item">
                <% purchase_orders_icon = raw('<svg class="portal-tab-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 2h9l5 5v15H6z"></path><path d="M14 2v6h6"></path><path d="M9 13h6"></path><path d="M9 17h6"></path></svg>') %>
                <%= link_to safe_join([purchase_orders_icon, content_tag(:span, "Purchase Orders")]), purchase_orders_path, class: ["nav-link", (controller_name == "purchase_orders" ? "active" : nil)].compact.join(" ") %>
              </li>
            </ul>
          <% end %>

          <div class="portal-actions d-flex align-items-center gap-2 ms-auto">
            <button class="btn btn-icon btn-outline-secondary" type="button" data-theme-toggle aria-label="Switch to dark mode" title="Switch to dark mode">
              <svg data-theme-icon="sun" hidden class="theme-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="4"></circle>
                <path d="M12 2v2"></path>
                <path d="M12 20v2"></path>
                <path d="m4.93 4.93 1.41 1.41"></path>
                <path d="m17.66 17.66 1.41 1.41"></path>
                <path d="M2 12h2"></path>
                <path d="M20 12h2"></path>
                <path d="m6.34 17.66-1.41 1.41"></path>
                <path d="m19.07 4.93-1.41 1.41"></path>
              </svg>
              <svg data-theme-icon="moon" class="theme-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20.99 13.13A8.5 8.5 0 1 1 10.87 3.01 7 7 0 0 0 20.99 13.13Z"></path>
              </svg>
            </button>

            <% if user_signed_in? %>
              <details class="account-menu position-relative">
                <summary class="btn btn-icon btn-outline-secondary" aria-label="My Account" title="My Account">
                  <svg class="theme-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M20 21a8 8 0 0 0-16 0"></path>
                    <circle cx="12" cy="7" r="4"></circle>
                  </svg>
                </summary>
                <div class="account-menu-panel dropdown-menu-end shadow-sm bg-body border rounded-3 p-2">
                  <div class="dropdown-header"><%= current_user.display_name %></div>
                  <%= link_to "Edit profile", edit_account_path, class: "dropdown-item rounded-2" %>
                  <div class="dropdown-divider"></div>
                  <%= button_to "Logout", destroy_user_session_path, method: :delete, class: "dropdown-item text-danger rounded-2", form_class: "m-0" %>
                </div>
              </details>
            <% else %>
              <%= link_to "Sign in", new_user_session_path, class: "btn btn-primary btn-sm rounded-pill px-3" %>
            <% end %>
          </div>
        </div>
      </nav>

      <% if content_for?(:page_title) || content_for?(:page_subtitle) %>
        <div class="portal-pagebar bg-body border-bottom">
          <div class="container py-3">
            <% if content_for?(:page_title) %>
              <h1 class="h4 mb-1"><%= content_for(:page_title) %></h1>
            <% end %>
            <% if content_for?(:page_subtitle) %>
              <p class="text-muted mb-0"><%= content_for(:page_subtitle) %></p>
            <% end %>
          </div>
        </div>
      <% end %>
    </header>

    <main class="container py-4">
      <% if notice.present? %>
        <div class="alert alert-success"><%= notice %></div>
      <% end %>
      <% if alert.present? %>
        <div class="alert alert-danger"><%= alert %></div>
      <% end %>
      <%= yield %>
    </main>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
