<!DOCTYPE html>
<html data-bs-theme="light">
  <head>
    <title><%= content_for(:title) || "DSS Vendor Portal" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <script>
      (() => {
        const storageKey = "dss-vendor-portal-theme"
        const systemTheme = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light"
        let storedTheme

        try {
          storedTheme = localStorage.getItem(storageKey)
        } catch {
          storedTheme = null
        }

        document.documentElement.setAttribute("data-bs-theme", storedTheme || systemTheme)
      })()
    </script>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-body-tertiary text-body">
    <header class="portal-header sticky-top">
      <div class="portal-utility text-white">
        <div class="container d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2 py-2">
          <div class="d-flex flex-wrap align-items-center gap-3 small">
            <span>DSS Vendor Portal</span>
            <span class="d-none d-sm-inline">Purchase order access for assigned dealers</span>
          </div>
          <div class="d-flex flex-wrap align-items-center gap-3 small">
            <% if user_signed_in? %>
              <%= link_to "My Account", edit_account_path, class: "portal-utility-link" %>
            <% else %>
              <%= link_to "Sign in", new_user_session_path, class: "portal-utility-link" %>
            <% end %>
          </div>
        </div>
      </div>

      <nav class="navbar navbar-expand-lg portal-navbar bg-body border-bottom">
        <div class="container">
          <%= link_to "DSS Vendor Portal", root_path, class: "navbar-brand fw-semibold" %>

          <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
          </button>

          <div class="collapse navbar-collapse" id="mainNavbar">
            <% if user_signed_in? %>
              <ul class="navbar-nav portal-tabs me-lg-auto my-3 my-lg-0 gap-lg-2">
                <li class="nav-item">
                  <% purchase_orders_icon = raw('<svg class="portal-tab-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 2h9l5 5v15H6z"></path><path d="M14 2v6h6"></path><path d="M9 13h6"></path><path d="M9 17h6"></path></svg>') %>
                  <%= link_to safe_join([purchase_orders_icon, content_tag(:span, "Purchase Orders")]), purchase_orders_path, class: ["nav-link", (controller_name == "purchase_orders" ? "active" : nil)].compact.join(" ") %>
                </li>
              </ul>
            <% end %>

            <ul class="navbar-nav ms-auto align-items-lg-center gap-2 mb-2 mb-lg-0">
              <% if user_signed_in? %>
                <li class="nav-item">
                  <%= link_to current_user.display_name, edit_account_path, class: "portal-user-chip text-decoration-none" %>
                </li>
              <% end %>
              <li class="nav-item">
                <button class="btn btn-icon btn-outline-secondary" type="button" data-theme-toggle aria-label="Switch to dark mode" title="Switch to dark mode">
                  <svg data-theme-icon="sun" hidden class="theme-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="4"></circle>
                    <path d="M12 2v2"></path>
                    <path d="M12 20v2"></path>
                    <path d="m4.93 4.93 1.41 1.41"></path>
                    <path d="m17.66 17.66 1.41 1.41"></path>
                    <path d="M2 12h2"></path>
                    <path d="M20 12h2"></path>
                    <path d="m6.34 17.66-1.41 1.41"></path>
                    <path d="m19.07 4.93-1.41 1.41"></path>
                  </svg>
                  <svg data-theme-icon="moon" class="theme-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M20.99 13.13A8.5 8.5 0 1 1 10.87 3.01 7 7 0 0 0 20.99 13.13Z"></path>
                  </svg>
                </button>
              </li>
              <% if user_signed_in? %>
                <li class="nav-item"><%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "btn btn-outline-secondary btn-sm rounded-pill px-3" %></li>
              <% else %>
                <li class="nav-item"><%= link_to "Sign in", new_user_session_path, class: "btn btn-primary btn-sm rounded-pill px-3" %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </nav>
    </header>

    <main class="container py-4">
      <% if notice.present? %>
        <div class="alert alert-success"><%= notice %></div>
      <% end %>
      <% if alert.present? %>
        <div class="alert alert-danger"><%= alert %></div>
      <% end %>
      <%= yield %>
    </main>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
