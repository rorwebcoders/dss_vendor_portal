<!DOCTYPE html>
<html data-bs-theme="light">
  <head>
    <title><%= content_for(:title) || "DSS Vendor Portal" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <script>
      (() => {
        const storageKey = "dss-vendor-portal-theme"
        const systemTheme = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light"
        let storedTheme

        try {
          storedTheme = localStorage.getItem(storageKey)
        } catch {
          storedTheme = null
        }

        document.documentElement.setAttribute("data-bs-theme", storedTheme || systemTheme)
      })()
    </script>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-body-tertiary text-body <%= "dealer-shell-enabled" if user_signed_in? %>">
    <% purchase_orders_icon = raw('<svg class="portal-nav-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 2h9l5 5v15H6z"></path><path d="M14 2v6h6"></path><path d="M9 13h6"></path><path d="M9 17h6"></path></svg>') %>
    <% account_icon = raw('<svg class="portal-nav-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21a8 8 0 0 0-16 0"></path><circle cx="12" cy="7" r="4"></circle></svg>') %>
    <% menu_icon = raw('<svg class="theme-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 6h16"></path><path d="M4 12h16"></path><path d="M4 18h16"></path></svg>') %>

    <header class="portal-header sticky-top">
      <nav class="navbar portal-navbar bg-body border-bottom">
        <div class="container-fluid d-flex align-items-center gap-2 gap-md-3 px-3 px-lg-4">
          <% if user_signed_in? %>
            <button class="btn btn-icon btn-outline-secondary portal-sidebar-toggle" type="button" data-sidebar-toggle aria-label="Toggle dealer navigation" aria-controls="dealer-sidebar" aria-expanded="true" title="Toggle dealer navigation">
              <%= menu_icon %>
            </button>
          <% end %>

          <%= link_to "DSS Vendor Portal", root_path, class: "navbar-brand fw-semibold me-auto" %>

          <div class="portal-actions d-flex align-items-center gap-2 ms-auto">
            <button class="btn btn-icon btn-outline-secondary" type="button" data-theme-toggle aria-label="Switch to dark mode" title="Switch to dark mode">
              <svg data-theme-icon="sun" hidden class="theme-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="4"></circle>
                <path d="M12 2v2"></path>
                <path d="M12 20v2"></path>
                <path d="m4.93 4.93 1.41 1.41"></path>
                <path d="m17.66 17.66 1.41 1.41"></path>
                <path d="M2 12h2"></path>
                <path d="M20 12h2"></path>
                <path d="m6.34 17.66-1.41 1.41"></path>
                <path d="m19.07 4.93-1.41 1.41"></path>
              </svg>
              <svg data-theme-icon="moon" class="theme-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20.99 13.13A8.5 8.5 0 1 1 10.87 3.01 7 7 0 0 0 20.99 13.13Z"></path>
              </svg>
            </button>

            <% if user_signed_in? %>
              <details class="account-menu position-relative">
                <summary class="btn btn-icon btn-outline-secondary" aria-label="My Account" title="My Account">
                  <%= account_icon %>
                </summary>
                <div class="account-menu-panel position-absolute end-0 mt-2 bg-body shadow-lg border rounded-4 overflow-hidden">
                  <div class="p-2">
                    <%= link_to edit_account_path,
                        class: "dropdown-item rounded-3 py-2 px-3 d-flex align-items-center" do %>
                      <span class="me-2">👤</span>
                      Edit Profile
                    <% end %>

                    <hr class="my-2">
                    <%= button_to destroy_user_session_path,
                        method: :delete,
                        class: "btn btn-light text-danger w-100 text-start border-0 rounded-3 py-2 px-3" do %>
                      🚪 Logout
                    <% end %>
                  </div>
                </div>
              </details>
            <% else %>
              <%= link_to "Sign in", new_user_session_path, class: "btn btn-primary btn-sm rounded-pill px-3" %>
            <% end %>
          </div>
        </div>
      </nav>
    </header>

    <% if user_signed_in? %>
      <div class="dealer-layout" data-dealer-layout>
        <aside class="dealer-sidebar bg-body" id="dealer-sidebar" data-dealer-sidebar aria-label="Dealer navigation">
          <div class="dealer-sidebar-inner">
            <div class="dealer-sidebar-heading">
              <span class="dealer-sidebar-kicker">Dealer</span>
              <strong class="dealer-sidebar-title">Workspace</strong>
            </div>

            <nav class="nav nav-pills flex-column dealer-side-nav" aria-label="Dealer sections">
              <%= link_to safe_join([purchase_orders_icon, content_tag(:span, "Purchase Orders", class: "dealer-side-nav-text")]), purchase_orders_path, class: ["nav-link", "dealer-side-nav-link", (controller_name == "purchase_orders" ? "active" : nil)].compact.join(" "), title: "Purchase Orders" %>
              <%= link_to safe_join([account_icon, content_tag(:span, "Profile", class: "dealer-side-nav-text")]), edit_account_path, class: ["nav-link", "dealer-side-nav-link", (controller_name == "accounts" ? "active" : nil)].compact.join(" "), title: "Profile" %>
            </nav>
          </div>
        </aside>
        <button class="dealer-sidebar-backdrop" type="button" data-sidebar-close aria-label="Close dealer navigation"></button>

        <div class="dealer-main-panel">
          <% if content_for?(:page_title) || content_for?(:page_subtitle) %>
            <div class="portal-pagebar bg-body border-bottom">
              <div class="container-fluid px-3 px-lg-4 py-3">
                <% if content_for?(:page_title) %>
                  <h1 class="h4 mb-1"><%= content_for(:page_title) %></h1>
                <% end %>
                <% if content_for?(:page_subtitle) %>
                  <p class="text-muted mb-0"><%= content_for(:page_subtitle) %></p>
                <% end %>
              </div>
            </div>
          <% end %>

          <main class="container-fluid px-3 px-lg-4 py-4">
            <% if notice.present? %>
              <div class="alert alert-success"><%= notice %></div>
            <% end %>
            <% if alert.present? %>
              <div class="alert alert-danger"><%= alert %></div>
            <% end %>
            <%= yield %>
          </main>
        </div>
      </div>
    <% else %>
      <main class="container py-4">
        <% if notice.present? %>
          <div class="alert alert-success"><%= notice %></div>
        <% end %>
        <% if alert.present? %>
          <div class="alert alert-danger"><%= alert %></div>
        <% end %>
        <%= yield %>
      </main>
    <% end %>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
