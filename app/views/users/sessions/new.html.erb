<% content_for :title, "Dealer Sign In" %>

<section class="dealer-login-page py-5">
  <div class="row align-items-center justify-content-center g-4">
    <div class="col-12 col-lg-6">
      <div class="dealer-login-hero text-white rounded-4 p-4 p-lg-5 h-100 shadow-sm">
        <span class="badge text-bg-light text-dark mb-3">Dealer Portal</span>
        <h1 class="display-6 fw-bold mb-3">Purchase orders for your assigned dealers.</h1>
        <p class="lead mb-4">
          Sign in with the account created by your administrator to review purchase orders and line items tied to your current dealer access.
        </p>
        <div class="row g-3">
          <div class="col-sm-4">
            <div class="dealer-login-stat rounded-3 p-3">
              <div class="fw-bold">Secure</div>
              <small>Devise login</small>
            </div>
          </div>
          <div class="col-sm-4">
            <div class="dealer-login-stat rounded-3 p-3">
              <div class="fw-bold">Scoped</div>
              <small>Dealer access</small>
            </div>
          </div>
          <div class="col-sm-4">
            <div class="dealer-login-stat rounded-3 p-3">
              <div class="fw-bold">Current</div>
              <small>Live membership</small>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12 col-md-9 col-lg-5">
      <div class="card dealer-login-card border-0 shadow-lg rounded-4">
        <div class="card-body p-4 p-lg-5">
          <div class="text-center mb-4">
            <div class="dealer-login-icon rounded-circle d-inline-flex align-items-center justify-content-center mb-3">
              <span class="fw-bold">DSS</span>
            </div>
            <h2 class="h3 fw-bold mb-1">Dealer Sign In</h2>
            <p class="text-muted mb-0">Use your portal credentials to continue.</p>
          </div>

          <form class="needs-validation" action="<%= session_path(resource_name) %>" accept-charset="UTF-8" method="post">
            <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

            <div class="form-floating mb-3">
              <input autofocus="autofocus" autocomplete="email" class="form-control form-control-lg" placeholder="you@example.com" type="email" name="user[email]" id="user_email">
              <label for="user_email">Email address</label>
            </div>

            <div class="form-floating mb-3">
              <input autocomplete="current-password" class="form-control form-control-lg" placeholder="Password" type="password" name="user[password]" id="user_password">
              <label for="user_password">Password</label>
            </div>

            <% if devise_mapping.rememberable? %>
              <div class="form-check mb-4">
                <input name="user[remember_me]" type="hidden" value="0">
                <input class="form-check-input" type="checkbox" value="1" name="user[remember_me]" id="user_remember_me">
                <label class="form-check-label" for="user_remember_me">Keep me signed in</label>
              </div>
            <% end %>

            <div class="d-grid mb-3">
              <button class="btn btn-primary btn-lg" type="submit">Sign in</button>
            </div>
          </form>

          <div class="alert alert-light border mb-0 small text-muted">
            Dealer accounts are created by admins only. Contact your portal administrator if you need access.
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
