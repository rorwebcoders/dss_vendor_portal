<% content_for :title, "Dealer Sign In" %>

<div class="row justify-content-center">
  <div class="col-12 col-md-8 col-lg-5">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-dark text-white text-center py-3">
        <h1 class="h4 mb-0">Dealer Sign In</h1>
      </div>
      <div class="card-body p-4">
        <p class="text-muted text-center mb-4">
          Sign in to view purchase orders for your assigned dealers.
        </p>

        <form class="needs-validation" action="<%= session_path(resource_name) %>" accept-charset="UTF-8" method="post">
          <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

          <div class="mb-3">
            <label class="form-label" for="user_email">Email</label>
            <input autofocus="autofocus" autocomplete="email" class="form-control" placeholder="you@example.com" type="email" name="user[email]" id="user_email">
          </div>

          <div class="mb-3">
            <label class="form-label" for="user_password">Password</label>
            <input autocomplete="current-password" class="form-control" placeholder="Password" type="password" name="user[password]" id="user_password">
          </div>

          <% if devise_mapping.rememberable? %>
            <div class="form-check mb-3">
              <input name="user[remember_me]" type="hidden" value="0">
              <input class="form-check-input" type="checkbox" value="1" name="user[remember_me]" id="user_remember_me">
              <label class="form-check-label" for="user_remember_me">Remember me</label>
            </div>
          <% end %>

          <div class="d-grid">
            <button class="btn btn-primary btn-lg" type="submit">Sign in</button>
          </div>
        </form>
      </div>
      <div class="card-footer bg-light text-center small text-muted">
        Need access? Contact your portal administrator to be added to a dealer.
      </div>
    </div>
  </div>
</div>
