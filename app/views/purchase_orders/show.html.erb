<% content_for :page_title, "Purchase Order #{@purchase_order.po_number}" %>
<% content_for :page_subtitle, @purchase_order.dealer&.name || "Unassigned" %>

<div class="mb-4">
  <%= link_to "← Back to Purchase Orders", purchase_orders_path, class: "btn btn-outline-secondary btn-sm" %>
</div>

<div class="card mb-4">
  <div class="card-header bg-body-tertiary">
    <h1 class="h4 mb-0">Purchase Order <%= @purchase_order.po_number %></h1>
  </div>
  <div class="card-body">
    <dl class="row mb-0">
      <dt class="col-sm-3">Dealer</dt>
      <dd class="col-sm-9"><%= @purchase_order.dealer&.name || "Unassigned" %></dd>

      <dt class="col-sm-3">PO ID</dt>
      <dd class="col-sm-9"><%= @purchase_order.po_id %></dd>

      <dt class="col-sm-3">PO Type</dt>
      <dd class="col-sm-9"><%= @purchase_order.po_type %></dd>

      <dt class="col-sm-3">Status</dt>
      <dd class="col-sm-9">
        <span class="badge text-bg-secondary"><%= @purchase_order.dealer_response&.titleize || "Empty" %></span>
      </dd>

      <dt class="col-sm-3">Created</dt>
      <dd class="col-sm-9"><%= l(@purchase_order.created_at, format: :long) %></dd>
    </dl>
  </div>
  <% if @purchase_order.pending_dealer_response? %>
    <div class="card-footer d-flex flex-column flex-sm-row gap-2 justify-content-end">
      <%= button_to "Reject PO", reject_purchase_order_path(@purchase_order), method: :patch, class: "btn btn-outline-danger", form: { data: { turbo_confirm: "Reject this purchase order and move it to unassigned?" } } %>
      <%= button_to "Accept PO", accept_purchase_order_path(@purchase_order), method: :patch, class: "btn btn-success" %>
    </div>
  <% end %>
</div>

<h2 class="h5 mb-3">Line Items</h2>
<% if @line_items.any? %>
  <div class="table-responsive">
    <table class="table table-bordered table-striped align-middle">
      <thead>
        <tr>
          <th>SKU</th>
          <th>Brand</th>
          <th>Title</th>
          <th class="text-end">Quantity</th>
          <th class="text-end">Cost</th>
        </tr>
      </thead>
      <tbody>
        <% @line_items.each do |line_item| %>
          <tr>
            <td><%= line_item.sku %></td>
            <td><%= line_item.brand %></td>
            <td><%= line_item.title %></td>
            <td class="text-end"><%= line_item.quantity %></td>
            <td class="text-end"><%= number_to_currency(line_item.cost) if line_item.cost.present? %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="alert alert-info">No line items have been added to this purchase order.</div>
<% end %>
