<% content_for :title, "Purchase Order #{@purchase_order.po_number}" %>
<div class="container-fluid purchase-order-show">
  <div class="purchase-orders-toolbar purchase-orders-toolbar mb-3 d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">

    <div>
      <p class="text-uppercase text-primary fw-semibold small mb-1">
        Purchase Order Details
      </p>

      <div class="d-flex flex-column flex-sm-row align-items-start align-items-sm-center gap-2">
        <h1 class="h3 fw-bold mb-0">
          <%= @purchase_order.po_number %>
        </h1>

        <span class="<%= purchase_order_status_badge_class(@purchase_order.dealer_response.to_s) %>">
          <%= @purchase_order.dealer_response&.titleize || "Empty" %>
        </span>
      </div>

      <p class="text-muted mb-0 mt-1">
        Review purchase order information and line items.
      </p>
    </div>

    <div class="d-flex gap-2">
      <%= link_to "Back", purchase_orders_path, class: "btn btn-outline-secondary" %>
      <% if @purchase_order.pending_dealer_response? %>
        <%= button_to "Reject", reject_purchase_order_path(@purchase_order),
            method: :patch, class: "btn btn-outline-danger",
            form: { onsubmit: "return confirm('Reject this purchase order?');" } %>
        <%#= button_to "Accept & Create Label", accept_purchase_order_path(@purchase_order), method: :patch, class: "btn btn-success" %>
      <% end %>
    </div>
  </div>

  <div class="row justify-content-center mb-4">
    <div class="col-12">

      <div class="card border-0 shadow-sm">
        <div class="card-header bg-white py-3">
          <div class="d-flex justify-content-between align-items-start">

            <!-- Title -->
            <div>
              <h5 class="mb-1 fw-bold">Shipping Label</h5>
              <small class="text-muted">
                Enter package weight and dimensions
              </small>
            </div>

            <!-- Tracking -->
            <% if @purchase_order.weight.to_s != "" %>
              <div class="text-end">
                <small class="text-muted d-block">Tracking Number</small>

                <% if @purchase_order.tracking_number.present? %>
                  <% if @purchase_order.shipstation_label_url.present? %>
                    <%= link_to @purchase_order.tracking_number,
                          @purchase_order.shipstation_label_url,
                          target: "_blank",
                          class: "fw-semibold text-primary text-decoration-none" %>
                  <% else %>
                    <span class="fw-semibold text-dark">
                      <%= @purchase_order.tracking_number %>
                    </span>
                  <% end %>
                <% else %>
                  <span class="badge bg-warning text-dark">
                    Label Generating...
                  </span>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>

        <div class="card-body">
          <%= form_with model: @purchase_order, local: true do |f| %>
            <div class="row g-3 align-items-end">
              <div class="col-12 col-md-2">
                <label class="form-label text-muted small">Weight</label>
                <%= f.number_field :weight,
                      class: "form-control",
                      required: true,
                      placeholder: "Weight" %>
              </div>

              <!-- Units -->
              <div class="col-12 col-md-2">
                <label class="form-label text-muted small">Units</label>
                <%= f.select :units,
                      [["Pounds (lb)", "pounds"], ["Ounces (oz)", "ounces"]],
                      {},
                      class: "form-select" %>
              </div>

              <!-- Length -->
              <div class="col-12 col-md-2">
                <label class="form-label text-muted small">Length</label>
                <%= f.number_field :length,
                      class: "form-control",
                      required: true,
                      placeholder: "L" %>
              </div>

              <!-- Width -->
              <div class="col-12 col-md-2">
                <label class="form-label text-muted small">Width</label>
                <%= f.number_field :width,
                      class: "form-control",
                      required: true,
                      placeholder: "W" %>
              </div>

              <!-- Height -->
              <div class="col-12 col-md-2">
                <label class="form-label text-muted small">Height</label>
                <%= f.number_field :height,
                      class: "form-control",
                      required: true,
                      placeholder: "H" %>
              </div>

              <!-- Submit -->
              <% if @purchase_order.weight.blank? %>
                <div class="col-12 col-md-2 d-grid">
                  <label class="form-label invisible">submit</label>
                  <%= f.submit "Accept & Create Label",
                        class: "btn btn-success btn-sm w-100 py-2" %>
                </div>
              <% end %>

            </div>
          <% end %>
        </div>
      </div>

    </div>
  </div>

  <!-- Meta Info -->
  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
      <div class="row g-4">
        
        <div class="col-12 col-md-6 col-lg-4">
          <div class="bor1der rounded p-3 h-100">
            <small class="text-muted text-uppercase d-block mb-2">
              Shipping Address
            </small>

            <div class="fw-semibold">
              <%= @purchase_order.shipping_firstname %> <%= @purchase_order.shipping_lastname %><br>
              <%= @purchase_order.shipping_address1 %><br>
              <%= @purchase_order.shipping_city %>, <%= @purchase_order.shipping_state %> <%= @purchase_order.shipping_zip %><br>
              <%= @purchase_order.shipping_country %>
            </div>
            <div class="text-muted small mt-2">
              <div><%= @purchase_order.shipping_phone %></div>
              <div><%= @purchase_order.shipping_email %></div>
            </div>
          </div>
        </div>

        <div class="col-12 col-md-6 col-lg-4">
          <div class="border1 rounded p-3 h-100">
            <small class="text-muted text-uppercase d-block mb-2">
              Created At
            </small>

            <div class="fw-semibold">
              <%= l(@purchase_order.created_at, format: :long) %>
            </div>
          </div>
        </div>

        <div class="col-12 col-md-6 col-lg-2">
          <div class="bord1er rounded p-3 h-100 text-center">
            <small class="text-muted text-uppercase d-block mb-2">
              Total Cost
            </small>

            <h3 class="mb-0 fw-bold text-primary">
              <%= number_to_currency(@line_items.sum { |item| item.cost.to_f }) %>
            </h3>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Line Items -->
  <div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 py-3">
      <div class="d-flex justify-content-between align-items-center">
        <h2 class="h5 mb-0 fw-bold">
          Line Items
        </h2>

        <span class="badge bg-light text-dark">
          <%= @total_line_items %> Items
        </span>
      </div>
    </div>

    <% if @line_items.any? %>

      <div class="table-responsive">
        <table class="table align-middle mb-0">

          <thead class="table-light">
            <tr>
              <th>SKU</th>
              <th class="text-end">Qty</th>
              <th class="text-end">Cost</th>
            </tr>
          </thead>

          <tbody id="line-items">
            <%= render partial: "purchase_orders/line_item", collection: @line_items, as: :line_item %>
          </tbody>
        </table>
        <div id="loading" class="text-center py-4" style="display:none;">
          <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
          </div>
        </div>
        <div id="scroll-sentinel" data-page="<%= @page %>" data-has-more="<%= @has_more %>"></div>
      </div>
    <% else %>
      <div class="card-body">
        <div class="alert alert-info mb-0">
          No line items available for this purchase order.
        </div>
      </div>
    <% end %>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const loadingEl = document.getElementById("loading")
    const sentinel = document.getElementById("scroll-sentinel")

    if (!sentinel) return

    let page = Number(sentinel.dataset.page || 1)
    let loading = false
    let hasMore = sentinel.dataset.hasMore === "true"

    const loadMore = async () => {
      if (loading || !hasMore) return

      loading = true
      if (loadingEl) loadingEl.style.display = "block"

      try {
        page += 1

        const url = new URL(window.location.href)
        url.searchParams.set("page", page)

        const res = await fetch(url.toString(), {
          headers: { Accept: "text/html" }
        })

        if (!res.ok) throw new Error(`HTTP ${res.status}`)

        const html = await res.text()
        const doc = new DOMParser().parseFromString(html, "text/html")

        const newRows = doc.querySelectorAll("#line-items tr")
        const tbody = document.getElementById("line-items")

        if (newRows.length === 0) {
          hasMore = false
          observer.disconnect()
          sentinel.innerHTML =
            '<div class="text-center text-muted py-3">No more line items</div>'
          return
        }

        newRows.forEach(row => tbody.appendChild(row))

        const newSentinel = doc.getElementById("scroll-sentinel")

        if (newSentinel) {
          hasMore = newSentinel.dataset.hasMore === "true"
          sentinel.dataset.hasMore = newSentinel.dataset.hasMore
        }

        if (!hasMore) {
          observer.disconnect()
          sentinel.innerHTML =
            '<div class="text-center text-muted py-3">No more line items</div>'
        }
      } catch (error) {
        console.error("Infinite scroll error:", error)
      } finally {
        loading = false
        if (loadingEl) loadingEl.style.display = "none"
      }
    }

    const observer = new IntersectionObserver(
      entries => {
        if (entries[0].isIntersecting) {
          loadMore()
        }
      },
      { rootMargin: "200px" }
    )

    observer.observe(sentinel)
  })
</script>

<style>
  .purchase-order-show .table td,
  .purchase-order-show .table th {
    padding: 0.7rem;
    vertical-align: middle;
  }

  .purchase-order-show .badge {
    font-weight: 500;
  }
</style>