<% content_for :title, "Purchase Order #{@purchase_order.po_number}" %>
<div class="container-fluid purchase-order-show">
  <div class="purchase-orders-toolbar purchase-orders-toolbar mb-3 d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
    <div>
      <p class="text-uppercase text-primary fw-semibold small mb-1">
        Purchase Order Details
      </p>

      <h1 class="h3 fw-bold mb-1">
        <%= @purchase_order.po_number %>
      </h1>

      <p class="text-muted mb-0">
        Review purchase order information and line items.
      </p>
    </div>

    <div class="d-flex gap-2">
      <%= link_to "Back", purchase_orders_path, class: "btn btn-outline-secondary" %>
      <% if @purchase_order.pending_dealer_response? %>
        <%= button_to "Reject", reject_purchase_order_path(@purchase_order),
            method: :patch, class: "btn btn-outline-danger",
            form: { data: { turbo_confirm: "Reject this purchase order?" } } %>
        <%= button_to "Accept", accept_purchase_order_path(@purchase_order), method: :patch, class: "btn btn-success" %>
      <% end %>
    </div>
  </div>

  <% if @purchase_order.dealer_response.to_s == "accepted" %>
    <div class="row justify-content-center mb-4">
      <div class="col-12">

        <div class="card border-0 shadow-sm">
          <div class="card-header bg-white py-3">
            <div class="d-flex justify-content-between align-items-start">

              <!-- Title -->
              <div>
                <h5 class="mb-1 fw-bold">Create Shipping Label</h5>
                <small class="text-muted">
                  Enter package weight and dimensions
                </small>
              </div>

              <!-- Tracking -->
              <% if @purchase_order.weight.to_s != "" %>
                <div class="text-end">
                  <small class="text-muted d-block">Tracking Number</small>

                  <% if @purchase_order.tracking_number.present? %>
                    <% if @purchase_order.shipstation_label_url.present? %>
                      <%= link_to @purchase_order.tracking_number,
                            @purchase_order.shipstation_label_url,
                            target: "_blank",
                            class: "fw-semibold text-primary text-decoration-none" %>
                    <% else %>
                      <span class="fw-semibold text-dark">
                        <%= @purchase_order.tracking_number %>
                      </span>
                    <% end %>
                  <% else %>
                    <span class="badge bg-warning text-dark">
                      Label Generating...
                    </span>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>

          <div class="card-body">
            <%= form_with model: @purchase_order, local: true do |f| %>

              <div class="row g-2 align-items-end">

                <!-- Weight -->
                <div class="col-12 col-md-2">
                  <label class="form-label">Weight</label>
                  <%= f.number_field :weight,
                        class: "form-control", required: true,
                        placeholder: "Weight" %>
                </div>

                <!-- Units -->
                <div class="col-12 col-md-2">
                  <label class="form-label">Units</label>
                  <%= f.select :units,
                          [["Pounds (lb)", "pounds"],
                           ["Ounces (oz)", "ounces"]],
                          {},
                          class: "form-select" %>
                </div>

                <!-- Length -->
                <div class="col-12 col-md-2">
                  <label class="form-label">Length</label>
                  <%= f.number_field :length,
                        class: "form-control", required: true,
                        placeholder: "L" %>
                </div>

                <!-- Width -->
                <div class="col-12 col-md-2">
                  <label class="form-label">Width</label>
                  <%= f.number_field :width,
                        class: "form-control", required: true,
                        placeholder: "W" %>
                </div>

                <!-- Height -->
                <div class="col-12 col-md-2">
                  <label class="form-label">Height</label>
                  <%= f.number_field :height,
                        class: "form-control", required: true,
                        placeholder: "H" %>
                </div>

                <% if @purchase_order.weight.to_s == "" %>
                  <div class="col-12 col-md-1 d-grid">
                    <label class="form-label invisible">.</label>
                    <%= f.submit "Create Label",
                          class: "btn btn-primary" %>
                  </div>
                <% end %>

              </div>
            <% end %>
          </div>
        </div>

      </div>
    </div>
  <% end %>

  <div class="row g-4 mb-4">
    <div class="col-md-6 col-xl-3">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <p class="text-muted small mb-2">Dealer</p>

          <h5 class="fw-semibold mb-0">
            <%= @purchase_order.dealer&.name || "Unassigned" %>
          </h5>
        </div>
      </div>
    </div>

    <div class="col-md-6 col-xl-3">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <p class="text-muted small mb-2">PO ID</p>
          <h5 class="fw-semibold mb-0">
            <%= @purchase_order.po_id %>
          </h5>
        </div>
      </div>
    </div>

    <div class="col-md-6 col-xl-3">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <p class="text-muted small mb-2">PO Type</p>
          <h5 class="fw-semibold mb-0">
            <%= @purchase_order.po_type %>
          </h5>
        </div>
      </div>
    </div>

    <div class="col-md-6 col-xl-3">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <p class="text-muted small mb-2">Status</p>

          <% badge_class =
              case @purchase_order.dealer_response
              when "accepted"
                "bg-success"
              when "rejected"
                "bg-danger"
              else
                "bg-warning text-dark"
              end
          %>

          <span class="badge <%= badge_class %> px-3 py-2 rounded-pill">
            <%= @purchase_order.dealer_response&.titleize || "Pending" %>
          </span>
        </div>
      </div>
    </div>
  </div>

  <!-- Meta Info -->
  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
      <div class="row g-4">
        <div class="col-12 col-md-6 col-lg-4">
          <div class="bor1der rounded p-3 h-100">
            <small class="text-muted text-uppercase d-block mb-2">
              Dealer Address
            </small>

            <div class="fw-semibold">
              <%= @purchase_order.dealer&.dealer_address1 %><br>
              <%= @purchase_order.dealer&.dealer_city %>,
              <%= @purchase_order.dealer&.dealer_state %>
              <%= @purchase_order.dealer&.dealer_zip %><br>
              <%= @purchase_order.dealer&.dealer_country %>
            </div>
          </div>
        </div>

        <div class="col-12 col-md-6 col-lg-4">
          <div class="border1 rounded p-3 h-100">
            <small class="text-muted text-uppercase d-block mb-2">
              Created At
            </small>

            <div class="fw-semibold">
              <%= l(@purchase_order.created_at, format: :long) %>
            </div>
          </div>
        </div>

        <div class="col-12 col-md-6 col-lg-2">
          <div class="borderq rounded p-3 h-100 text-center">
            <small class="text-muted text-uppercase d-block mb-2">
              Line Items
            </small>

            <h3 class="mb-0 fw-bold">
              <%= @line_items.count %>
            </h3>
          </div>
        </div>

        <div class="col-12 col-md-6 col-lg-2">
          <div class="bord1er rounded p-3 h-100 text-center">
            <small class="text-muted text-uppercase d-block mb-2">
              Total Cost
            </small>

            <h3 class="mb-0 fw-bold text-primary">
              <%= number_to_currency(@line_items.sum(&:cost)) %>
            </h3>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Line Items -->
  <div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 py-3">
      <div class="d-flex justify-content-between align-items-center">
        <h2 class="h5 mb-0 fw-bold">
          Line Items
        </h2>

        <span class="badge bg-light text-dark">
          <%= @line_items.count %> Items
        </span>
      </div>
    </div>

    <% if @line_items.any? %>

      <div class="table-responsive">
        <table class="table align-middle mb-0">

          <thead class="table-light">
            <tr>
              <th>SKU</th>
              <th>Brand</th>
              <th>Title</th>
              <th class="text-end">Qty</th>
              <th class="text-end">Cost</th>
            </tr>
          </thead>

          <tbody>
            <% @line_items.each do |line_item| %>
              <tr>
                <td class="fw-semibold">
                  <%= line_item.sku %>
                </td>

                <td>
                  <%= line_item.brand %>
                </td>

                <td>
                  <%= line_item.title %>
                </td>

                <td class="text-end">
                  <span class="badge bg-secondary-subtle text-dark px-3 py-2">
                    <%= line_item.quantity %>
                  </span>
                </td>

                <td class="text-end fw-semibold text-primary">
                  <%= number_to_currency(line_item.cost) if line_item.cost.present? %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="card-body">
        <div class="alert alert-info mb-0">
          No line items available for this purchase order.
        </div>
      </div>
    <% end %>
  </div>
</div>

<style>
  .purchase-order-show .table td,
  .purchase-order-show .table th {
    padding: 0.7rem;
    vertical-align: middle;
  }

  .purchase-order-show .badge {
    font-weight: 500;
  }
</style>