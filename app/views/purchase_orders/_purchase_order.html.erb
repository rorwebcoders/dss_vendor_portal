<tr>
  <td class="fw-semibold text-body">
    <% if @rejected %>
      <%= @rejected_data[purchase_order.id.to_s][:po_number] %>
    <% else %>
       <%= purchase_order.po_number %>
    <% end %>
  </td>
  <td>
    <% if @rejected %>
      <%= @rejected_data[purchase_order.id.to_s][:dealer_name] %>
    <% else %>
      <%= purchase_order.dealer&.dealer_name || "Unassigned" %>
    <% end %>
  </td>
  <td>
    <% if @rejected %>
      <span class="<%= purchase_order_status_badge_class(@rejected_data[purchase_order.id.to_s][:status].to_s) %>">
        <%= @rejected_data[purchase_order.id.to_s][:status]&.titleize || "Empty" %>
      </span>
    <% else %>
      <span class="<%= purchase_order_status_badge_class(purchase_order.dealer_response.to_s) %>">
        <%= purchase_order.dealer_response&.titleize || "Empty" %>
      </span>
    <% end %>
  </td>
  <td><%= l(purchase_order.created_at, format: :short) %></td>
  <td class="text-end">
    <div class="d-flex gap-2">
    <% if @rejected %>
      <%= link_to "View", "purchase_orders/#{purchase_order.id}?rejected=true", class: "btn btn-sm btn-primary rounded-pill px-3" %>
    <% else %>
      <%= link_to "View", purchase_order_path(purchase_order), class: "btn btn-sm btn-primary rounded-pill px-3" %>
    <% end %>
      <%# if purchase_order.pending_dealer_response? %>
        <%#= button_to "Accept", accept_purchase_order_path(purchase_order), method: :patch, class: "btn btn-sm rounded-pill btn-success" %>
        <%#= button_to "Reject", reject_purchase_order_path(purchase_order),
            method: :patch, class: "btn btn-sm rounded-pill btn-outline-danger",
            form: { onsubmit: "return confirm('Reject this purchase order?');" } %>
      <%# end %>
    </div>
  </td>
</tr>
