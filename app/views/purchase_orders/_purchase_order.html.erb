<tr>
  <td class="fw-semibold text-body">
    <% if @rejected %>
      <%= @rejected_data[purchase_order.id.to_s][:po_number] %>
    <% else %>
       <%= purchase_order.po_number %>
    <% end %>
  </td>
  <td>
    <% if @rejected %>
      <%= @rejected_data[purchase_order.id.to_s][:dealer_name] %>
    <% else %>
      <%= purchase_order.dealer&.dealer_name || "Unassigned" %>
    <% end %>
  </td>
  <td>
    <% if @rejected %>
      <span class="<%= purchase_order_status_badge_class(@rejected_data[purchase_order.id.to_s][:status].to_s) %>">
        <%= @rejected_data[purchase_order.id.to_s][:status]&.titleize || "Empty" %>
      </span>
    <% else %>
      <span class="<%= purchase_order_status_badge_class(purchase_order.dealer_response.to_s) %>">
        <%= purchase_order.dealer_response&.titleize || "Empty" %>
      </span>
    <% end %>
  </td>
  <% if !@rejected && params[:status] != 'accepted' %>
    <td>
      <% if purchase_order.pending_dealer_response? && purchase_order.dealer_assigned_at.present? %>
        <span
          class="dealer-countdown countdown"
          data-expires-at="<%= (purchase_order.dealer_assigned_at + 24.hours).to_i %>">
        </span>
      <% end %>
    </td>
  <% end %>
  <td><%= l(purchase_order.created_at, format: :short) %></td>
  <td class="text-end">
    <div class="d-flex gap-2">
    <% if @rejected %>
      <%= link_to "View", "purchase_orders/#{purchase_order.id}?rejected=true", class: "btn btn-sm btn-primary rounded-pill px-3" %>
    <% else %>
      <%= link_to "View", purchase_order_path(purchase_order), class: "btn btn-sm btn-primary rounded-pill px-3" %>
    <% end %>
      <%# if purchase_order.pending_dealer_response? %>
        <%#= button_to "Accept", accept_purchase_order_path(purchase_order), method: :patch, class: "btn btn-sm rounded-pill btn-success" %>
        <%#= button_to "Reject", reject_purchase_order_path(purchase_order),
            method: :patch, class: "btn btn-sm rounded-pill btn-outline-danger",
            form: { onsubmit: "return confirm('Reject this purchase order?');" } %>
      <%# end %>
    </div>
  </td>
</tr>

<script>
  function formatTime(ms) {
    const totalSeconds = Math.floor(ms / 1000);

    const hours = Math.floor(totalSeconds / 3600);
    const minutes = Math.floor((totalSeconds % 3600) / 60);
    const seconds = totalSeconds % 60;

    if (hours > 0) {
      return `${hours}h ${minutes}m remaining to accept or reject`;
    }

    return `${minutes}m ${seconds}s remaining to accept or reject`;
  }

  function updateDealerCountdowns() {
    $('.dealer-countdown').each(function () {
      const expiresAt = parseInt($(this).data('expires-at')) * 1000;
      const remaining = expiresAt - Date.now();

      if (remaining <= 0) {
        $(this)
          .text('Expired')
          .removeClass('countdown-warning')
          .addClass('countdown-danger');
        return;
      }

      if (remaining < 60 * 60 * 1000) {
        $(this)
          .text(formatTime(remaining))
          .removeClass('countdown-warning')
          .addClass('countdown-danger');
      } else {
        const hours = Math.ceil(remaining / (1000 * 60 * 60));

        $(this).text(`${hours} hours remaining to accept or reject`);

        if (remaining <= 6 * 60 * 60 * 1000) {
          $(this)
            .removeClass('countdown-danger')
            .addClass('countdown-warning');
        } else {
          $(this)
            .removeClass('countdown-warning countdown-danger');
        }
      }
    });
  }

  $(document).ready(function () {
    updateDealerCountdowns();
    setInterval(updateDealerCountdowns, 1000);
  });
</script>


<style>
.countdown {
  display: inline-block;
  font-weight: 500;
}

.countdown-normal {
  color: #6b7280;
}

.countdown-warning {
  color: #f59e0b;
}

.countdown-danger {
  color: #dc2626;
}
</style>