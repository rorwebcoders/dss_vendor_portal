<div class="purchase-orders-status-tabs mb-3" role="tablist" aria-label="Purchase order status filters">
  <% @status_filters.each do |status, label| %>
    <% active = @status_filter == status %>
    <% tab_path = purchase_orders_path(status: status, q: @query.presence, sort: @sort_column, direction: @sort_direction) %>
    <% tab_classes = ["purchase-orders-status-tab", ("active" if active)].compact.join(" ") %>
    <%= link_to label, tab_path, class: tab_classes, role: "tab", "aria-selected": active %>
  <% end %>
</div>

<div class="purchase-orders-toolbar mb-3">
  <div class="purchase-orders-toolbar-copy">
    <p class="text-uppercase text-primary fw-semibold small mb-1">Dealer PO list</p>
    <p class="text-muted small mb-0">Search and sort purchase orders assigned to your dealers.</p>
  </div>

  <%= form_with url: purchase_orders_path, method: :get, local: true, class: "purchase-orders-search" do |form| %>
    <%= form.hidden_field :status, value: @status_filter %>
    <%= form.hidden_field :sort, value: @sort_column %>
    <%= form.hidden_field :direction, value: @sort_direction %>
    <%= form.label :q, "Search purchase orders", class: "form-label visually-hidden" %>
    <div class="input-group input-group-sm">
      <span class="input-group-text" aria-hidden="true">
        <svg class="purchase-orders-search-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
      </span>
      <%= form.search_field :q, value: @query, class: "form-control", placeholder: "Search", autocomplete: "off" %>
      <%= form.submit "Go", class: "btn btn-primary" %>
      <% if @query.present? %>
        <%= link_to "Clear", purchase_orders_path(status: @status_filter, sort: @sort_column, direction: @sort_direction), class: "btn btn-outline-secondary" %>
      <% end %>
    </div>
  <% end %>
</div>

<div class="purchase-orders-summary-grid mb-4" aria-label="Purchase order summary">
  <% @purchase_order_summary_cards.each do |card| %>
    <article class="purchase-orders-summary-card purchase-orders-summary-card--<%= card[:modifier] %>">
      <p class="purchase-orders-summary-card-label"><%= card[:label] %></p>
      <p class="purchase-orders-summary-card-value"><%= card[:value] %></p>
      <p class="purchase-orders-summary-card-detail"><%= card[:detail] %></p>
    </article>
  <% end %>
</div>

<% if @purchase_orders.any? %>
  <div class="purchase-orders-card bg-body shadow-sm">
    <div class="table-responsive">
      <table class="table table-bordered table-hover align-middle purchase-orders-table">
        <thead>
          <tr>
            <th scope="col"><%= purchase_order_sort_link("po_number", "PO Number") %></th>
            <th scope="col"><%= purchase_order_sort_link("po_id", "PO ID") %></th>
            <th scope="col"><%= purchase_order_sort_link("po_type", "Type") %></th>
            <th scope="col"><%= purchase_order_sort_link("dealer", "Dealer") %></th>
            <th scope="col"><%= purchase_order_sort_link("status", "Status") %></th>
            <th scope="col"><%= purchase_order_sort_link("created", "Created") %></th>
            <th scope="col"><span class="visually-hidden">Actions</span></th>
          </tr>
        </thead>
        <tbody>
          <% @purchase_orders.each do |purchase_order| %>
            <tr>
              <td class="fw-semibold text-body"><%= purchase_order.po_number %></td>
              <td><%= purchase_order.po_id %></td>
              <td><%= purchase_order.po_type %></td>
              <td><%= purchase_order.dealer&.name || "Unassigned" %></td>
              <td>
                <span class="<%= purchase_order_status_badge_class(purchase_order.dealer_response.to_s) %>">
                  <%= purchase_order.dealer_response&.titleize || "Empty" %>
                </span>
              </td>
              <td><%= l(purchase_order.created_at, format: :short) %></td>
              <td class="text-end"><%= link_to "View", purchase_order_path(purchase_order), class: "btn btn-sm btn-primary rounded-pill px-3" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <% if @total_pages > 1 %>
    <div class="purchase-orders-pagination d-flex flex-column flex-md-row justify-content-md-end align-items-md-center gap-3 mt-4">
      <% if @total_purchase_orders.to_i.positive? %>
        <span class="badge text-bg-secondary rounded-pill align-self-start align-self-md-center"><%= @total_purchase_orders %> total</span>
      <% end %>
      <nav aria-label="Purchase order pages">
        <ul class="pagination flex-wrap gap-1 mb-0">
          <li class="page-item <%= "disabled" if @current_page == 1 %>">
            <%= link_to "Previous", purchase_orders_path(q: @query.presence, status: @status_filter, sort: @sort_column, direction: @sort_direction, page: @current_page - 1), class: "page-link" %>
          </li>
          <% purchase_order_pagination_pages(@current_page, @total_pages).each do |page| %>
            <% if page == :gap %>
              <li class="page-item disabled" aria-hidden="true"><span class="page-link">…</span></li>
            <% else %>
              <li class="page-item <%= "active" if page == @current_page %>">
                <%= link_to page, purchase_orders_path(q: @query.presence, status: @status_filter, sort: @sort_column, direction: @sort_direction, page: page), class: "page-link" %>
              </li>
            <% end %>
          <% end %>
          <li class="page-item <%= "disabled" if @current_page == @total_pages %>">
            <%= link_to "Next", purchase_orders_path(q: @query.presence, status: @status_filter, sort: @sort_column, direction: @sort_direction, page: @current_page + 1), class: "page-link" %>
          </li>
        </ul>
      </nav>
    </div>
  <% end %>
<% else %>
  <div class="alert alert-info">
    <% if @query.present? %>
      No purchase orders match “<%= @query %>”.
    <% else %>
      <% if @status_filter == "all" %>
        No purchase orders are available for your current dealer assignments.
      <% else %>
        No <%= @status_filters.fetch(@status_filter).downcase %> are available for your current dealer assignments.
      <% end %>
    <% end %>
  </div>
<% end %>
